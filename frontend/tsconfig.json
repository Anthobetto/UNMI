{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "jsx": "react-jsx",
    /* CAMBIO: De 'Node' a 'Bundler' para Vite */
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "isolatedModules": true,
    /* ELIMINADO: baseUrl se va. Ajustamos los paths abajo */
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../backend/shared/*"]
    },
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "../backend/shared/**/*",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}